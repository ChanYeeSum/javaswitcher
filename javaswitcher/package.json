{
  "name": "jdk-switcher",
  "version": "1.0.0",
  "description": "Quick switch between JDK versions on Windows",
  "author": "ChanYeeSum",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "make": "electron-forge make"
  },
  "keywords": ["jdk", "java", "switcher", "electron"],
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-squirrel": "^7.0.0",
    "@electron-forge/maker-zip": "^7.0.0",
    "electron": "^30.0.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true,
        "icon": "icon",
        "authors": ["ChanYeeSum"]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "jdk_switcher",
            "productName": "JDK Switcher",
            "exe": "jdk-switcher.exe",
            "authors": "ChanYeeSum",
            "description": "Quick switch between JDK versions on Windows",
            "iconUrl": "https://raw.githubusercontent.com/ChanYeeSum/javaswitcher/main/icon.ico"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "config": {
            "name": "jdk-switcher"
          }
        }
      ]
    }
  }
}
